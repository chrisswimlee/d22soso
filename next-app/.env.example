# Resend email delivery for the B2B licensing contact form.
# Get an API key at https://resend.com/api-keys
# If RESEND_API_KEY is unset, inquiries are logged to the server console instead of emailed.
RESEND_API_KEY=

# Where licensing inquiries are delivered.
CONTACT_TO_EMAIL=playbadugi@gmail.com

# Verified sender. Use a domain you've verified in Resend for production.
# The onboarding@resend.dev address only works for testing to your own account email.
CONTACT_FROM_EMAIL="Licensing <onboarding@resend.dev>"
